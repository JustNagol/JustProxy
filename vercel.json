{
  "version": 2,
  "buildCommand": "npm install",
  "builds": [{ "src": "index.js", "use": "@vercel/node" }],
  "routes": [
    { "src": "/",  "dest": "/index.html" },
    { "src": "/g", "dest": "/games.html" },
    { "src": "/m", "dest": "/media.html" },
    { "src": "/s", "dest": "/settings.html" },
    { "src": "/(.*)", "dest": "/index.js" }
  ]
}
